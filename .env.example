# Переменные окружения для Vercel
# Скопируйте этот файл в .env.local для разработки
# В Vercel добавьте эти переменные в настройках проекта

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Опционально: настройки для мок-сервера (если используется)
JSON_SERVER_PORT=3001